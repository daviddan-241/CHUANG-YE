# ============================================================
# DAVE Social AI — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Free AI (Groq) ───────────────────────────────────────────
# Sign up FREE at https://console.groq.com → Create API Key
# Models: llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fast)
GROQ_API_KEY="gsk_..."

# ── OpenAI (optional, paid) ──────────────────────────────────
OPENAI_API_KEY=""

# ── Telegram Real User Login ─────────────────────────────────
# Get API credentials from https://my.telegram.org/apps
# 1. Log in → API development tools → Create application
# 2. Copy App api_id and App api_hash
TELEGRAM_API_ID="12345678"
TELEGRAM_API_HASH="your_api_hash_here"

# Telegram Bot (optional — for sending broadcast messages via bot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Image Generation (optional) ──────────────────────────────
# ComfyUI local server
COMFYUI_API_URL="http://localhost:8188"

# Stable Diffusion WebUI
SD_API_URL="http://localhost:7860"

# ── Redis (optional — for BullMQ job queue) ──────────────────
REDIS_URL="redis://localhost:6379"

# ── Security ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="your-secure-encryption-key-here"

# ── App Settings ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Timezone (auto-set in Docker) ────────────────────────────
TZ="Asia/Shanghai"

# ── Proxy (optional — for browser automation) ────────────────
# HTTP_PROXY="http://proxy:port"
# HTTPS_PROXY="http://proxy:port"

# ── Brand Names ──────────────────────────────────────────────
BRAND_A_NAME="ChuangYe"
BRAND_B_NAME="VelocityEdge"
